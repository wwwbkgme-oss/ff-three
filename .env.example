# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://academy:secret@localhost:5432/forge_fabrik_academy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64

# ── Sandbox limits ────────────────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECS=30
SANDBOX_MAX_MEMORY_MB=128

# ── AI agents (optional – stubs activate when absent) ─────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=forge_api=debug,tower_http=info,sqlx=warn
