# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://academy:secret@localhost:5432/forge_fabrik_academy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64

# ── Sandbox limits ────────────────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECS=30
SANDBOX_MAX_MEMORY_MB=128

# ── LLM providers (free — set at least one) ───────────────────────────────────
#
# FreeClient tries providers in this order:
#   Groq → SambaNova → LLM7 → OpenRouter → NVIDIA NIM → Ollama (local)
#
# Any combination works.  Multiple active providers = automatic failover.
#
# Groq (fastest — 14 400 req/day, no credit card)
#   Sign up: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
#
# SambaNova (20–480 RPM, no credit card)
#   Sign up: https://cloud.sambanova.ai/apis
# SAMBANOVA_API_KEY=...
#
# LLM7.io (100 req/hr free gateway)
#   Token:   https://token.llm7.io/
# LLM7_API_KEY=...
#
# OpenRouter (:free models = $0.00/token)
#   Sign up: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
#
# NVIDIA NIM (1 000 free requests/month)
#   Sign up: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-...
#
# Ollama local (always free, requires: ollama serve)
#   Override host for non-default port:
# OLLAMA_HOST=http://localhost:11434

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=server=debug,drivers=info,tower_http=info,sqlx=warn
